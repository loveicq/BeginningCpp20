# 你原有的忽略项
.vscode/
bin/
images/
mindmap/
others/
logs/
MyCpp20Modules/
.vs/
# ==========================================
# Visual Studio 相关（不提交到仓库）
# ==========================================
.vs/                    # VS 本地配置（如 .vs 文件夹）
*.sln                   # 解决方案文件
*.vcxproj               # 项目文件
*.vcxproj.filters       # 项目筛选器
*.vcxproj.user          # 用户配置
*.vcxproj.*             # 其他项目备份

# ==========================================
# 编译输出（.obj、.exe、.pdb 等）
# ==========================================
Debug/
Release/
x64/
Win32/
*.obj
*.exe
*.pdb
*.ilk
*.exp
*.lib
*.dll
*.so
*.dylib

# ==========================================
# 编译中间目录
# ==========================================
out/
build/
cmake-build-*/
CMakeFiles/
CMakeCache.txt
*.cmake
Makefile

# ==========================================
# 模块编译生成的缓存文件（注意：不忽略 .cppm 源文件）
# ==========================================
*.ifc                     # 模块接口文件（由编译器生成）
*.ixx                     # 如果你不使用 .ixx，可忽略该类文件
*.ixx.ifc
*.gcm
gcm.cache/
tmp_build/                # 你的 std.obj 等临时目录

# ==========================================
# 其他 IDE 临时文件
# ==========================================
*.swp
*.swo
*~
.DS_Store
Thumbs.db
*.tmp
*.log

# ==========================================
# 保留源代码文件（不忽略）
# ==========================================
!*.cpp
!*.cppm                  # 确保 .cppm 后缀的模块文件不被忽略
!*.h
!*.hpp
!*.inl
!*.txt
